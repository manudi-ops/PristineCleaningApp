<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/white">

    <!-- Title: Pristine -->
    <ImageView
        android:id="@+id/imageView21"
        android:layout_width="81dp"
        android:layout_height="52dp"
        app:srcCompat="@drawable/download" />

    <TextView
        android:id="@+id/titleTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pristine"
        android:textSize="36sp"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="100dp"/>

    <!-- Tagline: We're about cleaning... -->
    <TextView
        android:id="@+id/taglineTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="We're about cleaning..."
        android:textSize="18sp"
        android:textColor="@color/gray"
        android:layout_below="@id/titleTextView"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"/>

    <!-- Button: Give Job -->
    <Button
        android:id="@+id/giveJobButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Give Job"
        android:textSize="18sp"
        android:backgroundTint="@color/teal_700"
        android:textColor="@color/white"
        android:layout_below="@id/taglineTextView"
        android:layout_marginTop="50dp"
        android:layout_marginLeft="32dp"
        android:layout_marginRight="32dp"
        android:padding="12dp"/>

    <!-- Button: Get Job -->
    <Button
        android:id="@+id/getJobButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Get Job"
        android:textSize="18sp"
        android:backgroundTint="@color/teal_700"
        android:textColor="@color/white"
        android:layout_below="@id/giveJobButton"
        android:layout_marginTop="16dp"
        android:layout_marginLeft="32dp"
        android:layout_marginRight="32dp"
        android:padding="12dp"/>

</RelativeLayout>
