<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Upload Image Section -->
        <ImageView
            android:id="@+id/imageView"
            android:layout_width="81dp"
            android:layout_height="78dp"
            app:srcCompat="@drawable/download" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upload Image"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/uploadImageButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Upload Image"
            android:backgroundTint="@color/purple_500"
            android:textColor="@color/white"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <ImageView
            android:id="@+id/jobImageView"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:background="@color/gray"
            android:layout_marginBottom="16dp" />

        <!-- Number of Rooms -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Number of rooms"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/numRoomsEditText"
            android:layout_width="match_parent"
            android:layout_height="66dp"
            android:layout_marginBottom="16dp"
            android:hint="Enter number"
            android:inputType="number" />

        <!-- Number of Bathrooms -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Number of bathrooms"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/numBathroomsEditText"
            android:layout_width="match_parent"
            android:layout_height="63dp"
            android:layout_marginBottom="16dp"
            android:hint="Enter number"
            android:inputType="number" />

        <!-- Including Other Common Area -->
        <CheckBox
            android:id="@+id/commonAreaCheckBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Including other common area"
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <!-- Total Square Feet -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Space in total sq ft"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/totalSqFtEditText"
            android:layout_width="match_parent"
            android:layout_height="71dp"
            android:layout_marginBottom="16dp"
            android:hint="Enter number"
            android:inputType="numberDecimal" />

        <!-- Cleaning Type -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cleaning Type"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <CheckBox
            android:id="@+id/generalCleaningCheckBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="General cleaning"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <CheckBox
            android:id="@+id/heavyCleaningCheckBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Heavy cleaning"
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <!-- Type of Flooring -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Type of flooring"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/flooringTypeRadioGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/tileRadioButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tile"
                android:textSize="16sp" />

            <RadioButton
                android:id="@+id/hardwoodRadioButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hardwood"
                android:textSize="16sp" />

            <RadioButton
                android:id="@+id/carpetRadioButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Carpet"
                android:textSize="16sp" />

            <RadioButton
                android:id="@+id/concreteRadioButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Concrete"
                android:textSize="16sp" />

            <RadioButton
                android:id="@+id/otherRadioButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Other"
                android:textSize="16sp" />
        </RadioGroup>

        <!-- Estimated Cost -->
        <TextView
            android:id="@+id/estimatedCostTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estimated Cost: $0.00"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:layout_marginBottom="16dp" />

        <!-- Post Job Button -->
        <Button
            android:id="@+id/postJobButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Post job"
            android:backgroundTint="@color/purple_500"
            android:textColor="@color/white"
            android:padding="12dp" />
    </LinearLayout>
</ScrollView>